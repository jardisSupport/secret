{
    "name": "jardissupport/secret",
    "description": "Secret resolution library for decrypting encrypted values in .env files and other contexts",
    "type": "library",
    "license": "PolyForm-Noncommercial-1.0.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Core Development",
            "email": "jardisCore@headgent.dev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardisport/secret": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Secret\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Secret\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisSupport/secret",
    "support": {
        "issues": "https://github.com/jardisSupport/secret/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "secret",
        "encryption",
        "aes",
        "sodium",
        "dotenv",
        "environment",
        "domain driven design",
        "jardisSupport",
        "jardisport",
        "jardis",
        "Headgent"
    ]
}
