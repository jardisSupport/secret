{
    "name": "jardissupport/secret",
    "homepage": "https://docs.jardis.io/en/support/secret",
    "description": "Secret resolution for encrypted configuration values using AES-256-GCM and Sodium with key provider abstraction",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Core Development",
            "email": "jardisCore@headgent.dev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2",
        "ext-openssl": "*",
        "ext-sodium": "*"
    },
    "suggest": {
        "ext-openssl": "Required for AES-256-GCM encryption (AesSecretResolver)",
        "ext-sodium": "Required for Sodium encryption (SodiumSecretResolver)"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Secret\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Secret\\Tests\\": "tests/"
        }
    },    "support": {
        "issues": "https://github.com/jardisSupport/secret/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "secret",
        "encryption",
        "aes",
        "sodium",
        "dotenv",
        "environment",
        "domain driven design",
        "jardisSupport",
        "jardisport",
        "jardis",
        "Headgent"
    ]
}
